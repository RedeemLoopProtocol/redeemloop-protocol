{
  "name": "@redeemloop/api",
  "private": true,
  "version": "0.9.3",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "predev": "pnpm --filter @redeemloop/core build && pnpm --filter @redeemloop/adapters build",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "worker": "node dist/webhook-worker.js",
    "worker:dev": "tsx src/webhook-worker.ts",
    "prebuild": "pnpm --filter @redeemloop/core build && pnpm --filter @redeemloop/adapters build",
    "build": "tsc -p tsconfig.json",
    "pretest": "pnpm --filter @redeemloop/core build && pnpm --filter @redeemloop/adapters build",
    "test": "vitest run",
    "lint": "tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@redeemloop/adapters": "workspace:*",
    "@redeemloop/core": "workspace:*",
    "fastify": "^5.2.1",
    "pg": "^8.22.0",
    "viem": "^2.22.17"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
