# RedeemLoop public merchant sandbox
NODE_ENV=production
HOST=0.0.0.0
PORT=3002
# Use REDEEMLOOP_DATABASE_URL for managed Postgres persistence. If it is set,
# it takes precedence over REDEEMLOOP_STORAGE_FILE.
# REDEEMLOOP_DATABASE_URL=postgres://redeemloop:redeemloop@postgres:5432/redeemloop
# REDEEMLOOP_DATABASE_SNAPSHOT_KEY=default
REDEEMLOOP_STORAGE_FILE=.redeemloop/state.json
REDEEMLOOP_API_KEYS='{"merchant_cafe":"dev-secret"}'
REDEEMLOOP_EMBED_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
EVM_MIN_CONFIRMATIONS=1
WEBHOOK_MAX_ATTEMPTS=5
WEBHOOK_DELIVERY_LEASE_MS=60000
WEBHOOK_REQUEST_TIMEOUT_MS=15000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
RELAYER_DRY_RUN=true

# Optional webhook worker process. The Docker Compose sandbox runs this as a
# separate service and does not expose another host port.
# REDEEMLOOP_API_BASE_URL=http://localhost:3002
# REDEEMLOOP_WORKER_MERCHANT_ID=merchant_cafe
# REDEEMLOOP_WORKER_API_KEY=dev-secret
# REDEEMLOOP_WORKER_INTERVAL_MS=5000
# REDEEMLOOP_WORKER_BATCH_SIZE=25
# REDEEMLOOP_WORKER_REQUEST_TIMEOUT_MS=20000

# Optional trusted EVM receipt recheck.
# RPC_URL=https://base-mainnet.example
# Optional multi-chain EVM receipt recheck. Values may be JSON or chainId:url pairs.
# EVM_RPC_URLS='{"1":"https://eth.example","56":"https://bsc.example","137":"https://polygon.example","42161":"https://arb.example"}'

# Optional Bitcoin Rune settlement recheck through Xverse API.
# XVERSE_API_KEY=xverse-api-key
# XVERSE_NETWORK=mainnet
# XVERSE_API_BASE_URL=https://api.secretkeylabs.io

# Optional commerce adapters.
# SHOPIFY_SHOP_DOMAIN=example.myshopify.com
# SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxx
# SHOPIFY_ADMIN_API_VERSION=2026-04
# SHOPIFY_WEBHOOK_SECRET=replace-me
# WOOCOMMERCE_STORE_URL=https://merchant.example
# WOOCOMMERCE_CONSUMER_KEY=ck_xxx
# WOOCOMMERCE_CONSUMER_SECRET=cs_xxx
# WOOCOMMERCE_WEBHOOK_SECRET=replace-me
